# AlphaMed shared DB configuration
# Copy to .env for local development, or provide these values through the deployment environment.

# Async SQLAlchemy URL used by shared.db and Alembic.
# Production example:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/alphamed
# Provider URLs pasted as postgres://... or postgresql://... are normalized automatically.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/alphamed

# Schema where Alembic stores this project's alembic_version table.
# This keeps AlphaMed migration history separate from other projects in the same database.
# Current models/migration still create application tables in the default PostgreSQL schema.
DB_SCHEMA=alphamed

# SQLAlchemy echo logging. Keep false in production.
DEBUG=false

# Existing production DB note:
#   uv sync --group migration
#   uv run alembic stamp 9fe7951d61a0
# This creates/updates alphamed.alembic_version. The old public.alembic_version can be
# removed manually only after confirming no other project needs it.
#
# New empty DB note:
#   uv run alembic upgrade head
